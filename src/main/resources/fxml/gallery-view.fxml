<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e); -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.photogallery.controllers.GalleryController" prefWidth="950" prefHeight="700">

    <Label style="-fx-text-fill: linear-gradient(to right, #ff6b6b, #ff8e8e); -fx-font-size: 26px; -fx-font-weight: bold;" text="📸 PhotoGallery"/>

    <HBox spacing="15">
        <Button fx:id="addImageButton" onAction="#onAddImage" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button fx:id="reverseOrderButton" onAction="#onReverseOrder" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <StackPane fx:id="imageContainer" style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-background-radius: 20; -fx-padding: 12;" prefHeight="450" prefWidth="800">
        <ImageView fx:id="displayArea" fitHeight="450" fitWidth="800" preserveRatio="true"/>
    </StackPane>

    <Label fx:id="counterLabel" alignment="CENTER" style="-fx-text-fill: #e0e0e0; -fx-font-size: 14px; -fx-font-weight: bold;"/>

    <HBox spacing="8" alignment="CENTER">
        <TextField fx:id="hashtagInput" promptText="#хэштег" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 6 12;"/>
        <Button fx:id="addHashtagButton" onAction="#onAddHashtag"
                style="-fx-background-color: linear-gradient(to bottom, #4a5e7a, #2a3a5a); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 12; -fx-cursor: hand;"
                text="➕"/>
    </HBox>

    <HBox alignment="CENTER" spacing="15">
        <Label text="Реакция:" style="-fx-text-fill: #e0e0e0; -fx-font-size: 13px;"/>
        <ComboBox fx:id="emotionSelector" onAction="#onEmotionChanged" prefWidth="90"
                  style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 18px; -fx-background-radius: 20;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="12">
        <Button fx:id="firstButton" onAction="#onFirstSlide" prefWidth="55" prefHeight="55"/>
        <Button fx:id="prevButton" onAction="#onPreviousClick" prefWidth="55" prefHeight="55"/>
        <Button fx:id="playButton" onAction="#onStartSlideshow" prefWidth="55" prefHeight="55"/>
        <Button fx:id="stopButton" onAction="#onStopSlideshow" prefWidth="55" prefHeight="55"/>
        <Button fx:id="nextButton" onAction="#onNextClick" prefWidth="55" prefHeight="55"/>
        <Button fx:id="lastButton" onAction="#onLastSlide" prefWidth="55" prefHeight="55"/>
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Label text="Интервал (мс):" style="-fx-text-fill: #e0e0e0; -fx-font-size: 12px;"/>
        <TextField fx:id="intervalInput" prefWidth="100"
                   style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 10;"/>
        <Button fx:id="applyIntervalButton" onAction="#onApplyInterval" text="Применить"
                style="-fx-background-color: linear-gradient(to bottom, #4a5e7a, #2a3a5a); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 5 12; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="musicButton" onAction="#onToggleMusic"
                style="-fx-background-color: linear-gradient(to bottom, #4a5e7a, #2a3a5a); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 5 12; -fx-cursor: hand;"
                text="🎵"/>
        <Slider fx:id="volumeSlider" prefWidth="100"
                style="-fx-control-inner-background: #ff6b6b; -fx-background-color: #4a5e7a;"/>
        <Label fx:id="volumeLabel" style="-fx-text-fill: #e0e0e0; -fx-font-size: 11px;" text="50%"/>
    </HBox>

</VBox>